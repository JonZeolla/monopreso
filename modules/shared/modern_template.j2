<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="modules/shared/css/modern.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html { scroll-behavior: smooth; }
        .slide {
            min-height: 100vh;
            scroll-snap-align: start;
        }
        .scroll-container {
            scroll-snap-type: y mandatory;
            overflow-y: scroll;
            height: 100vh;
        }
        .fade-in { animation: fadeIn 0.6s ease-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .nav-dot {
            transition: all 0.3s ease;
            position: relative;
        }
        .nav-dot.active {
            transform: scale(1.5);
            background: #00BAAE;
        }
        .nav-dot::before {
            content: attr(data-label);
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            background: #1D2939;
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease;
            border: 1px solid #374151;
        }
        .nav-dot:hover::before {
            opacity: 1;
        }
        .timeline-node {
            transition: all 0.3s ease;
        }
        .timeline-node:hover {
            transform: scale(1.15);
        }
        .timeline-node:hover .timeline-tooltip {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }
        .timeline-tooltip {
            opacity: 0;
            visibility: hidden;
            transform: translateX(-50%) translateY(10px);
            transition: all 0.3s ease;
        }
        .gradient-text {
            background: linear-gradient(90deg, #00BAAE, #0071DA);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        /* Filesystem explorer */
        .fs-item { transition: all 0.2s ease; }
        .fs-item:hover, .fs-item-active { background: rgba(0, 186, 174, 0.1); }
        .fs-detail-content.hidden { display: none; }
        /* Hidden slides */
        .hidden-slide {
            display: none !important;
        }
        .show-hidden .hidden-slide {
            display: flex !important;
        }
        .hidden-slide-dot {
            display: none;
        }
        .show-hidden .hidden-slide-dot {
            display: block;
        }

        /* Print / PDF export styles */
        @media print {
            @page {
                size: landscape;
                margin: 0;
            }
            html, body {
                height: auto !important;
                overflow: visible !important;
                background: #0B1120 !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            .scroll-container {
                height: auto !important;
                overflow: visible !important;
                scroll-snap-type: none !important;
            }
            .slide, section.slide {
                min-height: 100vh !important;
                height: 100vh !important;
                page-break-after: always !important;
                break-after: page !important;
                page-break-inside: avoid !important;
                break-inside: avoid !important;
                overflow: hidden !important;
            }
            .slide:last-child {
                page-break-after: auto !important;
                break-after: auto !important;
            }
            /* Hide UI chrome */
            #nav-dots,
            .nav-dot,
            .fixed {
                display: none !important;
            }
            /* Ensure backgrounds print */
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            /* Disable animations */
            .fade-in {
                animation: none !important;
            }
            /* Ensure gradient text prints */
            .gradient-text {
                -webkit-text-fill-color: #00BAAE !important;
            }
        }
    </style>
</head>
<body class="font-sans text-slate-200 bg-zenable-bg">
    <!-- Navigation Dots (auto-generated) -->
    <nav class="fixed right-6 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-3" id="nav-dots"></nav>

    <!-- Keyboard hint -->
    <div class="fixed bottom-6 left-6 text-xs text-slate-500 z-50">
        <kbd class="px-2 py-1 bg-zenable-bg-light rounded border border-slate-700">&uarr;</kbd>
        <kbd class="px-2 py-1 bg-zenable-bg-light rounded border border-slate-700">&darr;</kbd>
        or scroll to navigate
    </div>

    <div class="scroll-container" id="container">
{{ content }}
    </div>

    <script>
        // Auto-generate nav dots from slide sections
        (function() {
            const container = document.getElementById('container');
            const nav = document.getElementById('nav-dots');
            const slides = container.querySelectorAll(':scope > section.slide, :scope > section:not(.slide)');

            // Build slide_labels from data-label attributes or fallback to index
            slides.forEach((slide, i) => {
                const label = slide.getAttribute('data-label') || ('Slide ' + i);
                const isHidden = slide.classList.contains('hidden-slide');
                const btn = document.createElement('button');
                btn.className = 'nav-dot w-3 h-3 rounded-full bg-slate-600 hover:bg-zenable-teal' +
                    (i === 0 ? ' active' : '') +
                    (isHidden ? ' hidden-slide-dot' : '');
                btn.setAttribute('data-slide', i);
                btn.setAttribute('data-label', label);
                btn.onclick = function() { goToSlide(i); };
                nav.appendChild(btn);
            });
        })();

        const container = document.getElementById('container');
        const allSlides = container.querySelectorAll(':scope > section.slide, :scope > section:not(.slide)');
        const allDots = document.querySelectorAll('.nav-dot');

        function goToSlide(index, smooth) {
            if (smooth === undefined) smooth = true;
            allSlides[index].scrollIntoView({ behavior: smooth ? 'smooth' : 'auto' });
            updateURL(index);
        }

        function updateURL(index) {
            const url = new URL(window.location);
            url.searchParams.set('slide', index);
            history.replaceState(null, '', url);
        }

        // Update active dot on scroll
        let scrollTimeout;
        container.addEventListener('scroll', function() {
            const scrollPos = container.scrollTop;
            const windowHeight = window.innerHeight;
            const showHidden = document.body.classList.contains('show-hidden');
            let activeIndex = 0;

            allSlides.forEach(function(slide, index) {
                if (!showHidden && slide.classList.contains('hidden-slide')) return;
                if (scrollPos >= slide.offsetTop - windowHeight / 2) {
                    activeIndex = index;
                }
            });

            allDots.forEach(function(d) { d.classList.remove('active'); });
            if (allDots[activeIndex]) allDots[activeIndex].classList.add('active');
            targetSlideIndex = activeIndex;

            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(function() { updateURL(activeIndex); }, 100);
        });

        // Load slide from URL on page load
        var urlParams = new URLSearchParams(window.location.search);
        var startSlide = parseInt(urlParams.get('slide')) || 0;
        if (startSlide > 0 && startSlide < allSlides.length) {
            setTimeout(function() { goToSlide(startSlide, false); }, 50);
        }

        // Keyboard navigation
        var targetSlideIndex = 0;
        var lastNavTime = 0;
        var rapidNavThreshold = 200;

        function getNextVisibleSlide(currentIndex, direction) {
            var showHidden = document.body.classList.contains('show-hidden');
            var newIndex = currentIndex + direction;
            while (newIndex >= 0 && newIndex < allSlides.length) {
                if (showHidden || !allSlides[newIndex].classList.contains('hidden-slide')) {
                    return newIndex;
                }
                newIndex += direction;
            }
            return currentIndex;
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'h' || e.key === 'H') {
                document.body.classList.toggle('show-hidden');
                return;
            }

            var now = Date.now();
            var isRapid = (now - lastNavTime) < rapidNavThreshold;
            lastNavTime = now;

            if (e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown') {
                e.preventDefault();
                var nextIndex = getNextVisibleSlide(targetSlideIndex, 1);
                if (nextIndex !== targetSlideIndex) {
                    targetSlideIndex = nextIndex;
                    goToSlide(targetSlideIndex, !isRapid);
                }
            } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
                e.preventDefault();
                var prevIndex = getNextVisibleSlide(targetSlideIndex, -1);
                if (prevIndex !== targetSlideIndex) {
                    targetSlideIndex = prevIndex;
                    goToSlide(targetSlideIndex, !isRapid);
                }
            }
        });
        // Filesystem explorer: click folder to show detail panel
        document.addEventListener('click', function(e) {
            var fsItem = e.target.closest('.fs-item[data-fs-detail]');
            if (!fsItem) return;
            var detailId = fsItem.getAttribute('data-fs-detail');
            var explorer = fsItem.closest('.fs-explorer');
            if (!explorer) return;
            explorer.querySelectorAll('.fs-item').forEach(function(i) { i.classList.remove('fs-item-active'); });
            fsItem.classList.add('fs-item-active');
            explorer.querySelectorAll('.fs-detail-content').forEach(function(d) { d.classList.add('hidden'); });
            var target = explorer.querySelector('[data-fs-detail-id="' + detailId + '"]');
            if (target) target.classList.remove('hidden');
        });
    </script>
</body>
</html>
