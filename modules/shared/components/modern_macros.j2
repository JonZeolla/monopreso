{# ============================================================
   Modern presentation macros — Tailwind-styled HTML generators
   ============================================================ #}

{# ---------- title_slide ---------- #}
{%- macro title_slide(title, subtitle="", tags=[]) -%}
<section class="slide flex items-center justify-center p-12" id="slide-{{ caller.slide_index|default(0) }}">
  <div class="text-center fade-in">
    <h1 class="text-7xl font-bold mb-4 tracking-tight text-white">{{ title }}</h1>
    {%- if subtitle %}
    <p class="text-2xl font-medium mb-8 italic gradient-text">{{ subtitle }}</p>
    {%- endif %}
    {%- if tags %}
    <div class="flex gap-4 justify-center text-sm text-slate-300 flex-wrap">
      {%- for tag in tags %}
      <span class="bg-zenable-bg-light/30 px-4 py-2 rounded-full border border-zenable-teal/30">{{ tag }}</span>
      {%- endfor %}
    </div>
    {%- endif %}
    <div class="mt-16 text-slate-500 animate-bounce">
      <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>
{%- endmacro -%}

{# ---------- section_header ---------- #}
{%- macro section_header(label, title, subtitle="") -%}
<section class="slide flex items-center justify-center p-12">
  <div class="text-center fade-in">
    <h2 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-zenable-teal mb-3">{{ label }}</h2>
    <h3 class="text-5xl font-bold gradient-text">{{ title }}</h3>
    {%- if subtitle %}
    <p class="text-xl text-slate-400 mt-4">{{ subtitle }}</p>
    {%- endif %}
  </div>
</section>
{%- endmacro -%}

{# ---------- section_label ---------- #}
{%- macro section_label(text) -%}
<h2 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-zenable-teal mb-3">{{ text }}</h2>
{%- endmacro -%}

{# ---------- pill ---------- #}
{%- macro pill(text, color="teal") -%}
{%- if color == "blue" -%}
<span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-zenable-blue/15 text-zenable-blue border border-zenable-blue/30">{{ text }}</span>
{%- elif color == "amber" -%}
<span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-amber-500/15 text-amber-400 border border-amber-500/30">{{ text }}</span>
{%- else -%}
<span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-zenable-teal/15 text-zenable-teal border border-zenable-teal/30">{{ text }}</span>
{%- endif -%}
{%- endmacro -%}

{# ---------- card ---------- #}
{%- macro card(title, desc, accent="teal") -%}
<div class="bg-zenable-bg-light/50 border border-slate-700 rounded-xl p-6 hover:border-zenable-{{ accent }}/40 transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20">
  <div class="flex items-center gap-3 mb-2">
    {%- if accent == "teal" %}
    <div class="w-1 h-8 bg-zenable-teal rounded-full flex-shrink-0"></div>
    {%- elif accent == "blue" %}
    <div class="w-1 h-8 bg-zenable-blue rounded-full flex-shrink-0"></div>
    {%- elif accent == "amber" %}
    <div class="w-1 h-8 bg-amber-400 rounded-full flex-shrink-0"></div>
    {%- endif %}
    <h4 class="text-lg font-semibold text-white">{{ title }}</h4>
  </div>
  <p class="text-sm text-slate-400">{{ desc }}</p>
</div>
{%- endmacro -%}

{# ---------- card_grid ---------- #}
{%- macro card_grid(cards, cols=2) -%}
<div class="grid grid-cols-{{ cols }} gap-6 mt-6">
  {%- for c in cards %}
  {{ card(c.title, c.desc, c.accent|default("teal")) }}
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- split_personas ---------- #}
{%- macro split_personas(left_title, left_subtitle, left_items, right_title, right_subtitle, right_items) -%}
<section class="slide flex items-center">
  <div class="w-full min-h-screen flex relative">
    <!-- Left side -->
    <div class="w-1/2 min-h-screen flex flex-col justify-center p-12 pr-16 bg-gradient-to-br from-zenable-teal/5 to-transparent">
      <div class="max-w-md ml-auto">
        <div class="flex flex-col items-center text-center mb-10">
          <h3 class="text-2xl font-bold text-white mb-1">{{ left_title }}</h3>
          <p class="text-sm text-slate-500">{{ left_subtitle }}</p>
        </div>
        <div class="space-y-4">
          {%- for item in left_items %}
          <div class="group p-4 rounded-xl bg-zenable-bg-light/40 border border-slate-700/50 hover:border-zenable-teal/40 transition-all">
            <h4 class="font-semibold text-white mb-1">{{ item.title }}</h4>
            <p class="text-sm text-slate-400">{{ item.desc }}</p>
          </div>
          {%- endfor %}
        </div>
      </div>
    </div>
    <!-- Center divider -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-2/3 w-px bg-gradient-to-b from-transparent via-zenable-teal to-zenable-blue opacity-50"></div>
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-gradient-to-br from-zenable-teal to-zenable-blue"></div>
    <!-- Right side -->
    <div class="w-1/2 min-h-screen flex flex-col justify-center p-12 pl-16 bg-gradient-to-bl from-zenable-blue/5 to-transparent">
      <div class="max-w-md">
        <div class="flex flex-col items-center text-center mb-10">
          <h3 class="text-2xl font-bold text-white mb-1">{{ right_title }}</h3>
          <p class="text-sm text-slate-500">{{ right_subtitle }}</p>
        </div>
        <div class="space-y-4">
          {%- for item in right_items %}
          <div class="group p-4 rounded-xl bg-zenable-bg-light/40 border border-slate-700/50 hover:border-zenable-blue/40 transition-all">
            <h4 class="font-semibold text-white mb-1">{{ item.title }}</h4>
            <p class="text-sm text-slate-400">{{ item.desc }}</p>
          </div>
          {%- endfor %}
        </div>
      </div>
    </div>
    <!-- Title -->
    <div class="absolute top-12 left-1/2 -translate-x-1/2 text-center">
      <h2 class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Designed for</h2>
    </div>
  </div>
</section>
{%- endmacro -%}

{# ---------- timeline ---------- #}
{%- macro timeline(nodes) -%}
<div class="relative">
  <div class="absolute top-6 left-0 right-0 h-1 bg-slate-700 rounded"></div>
  <div class="absolute top-6 left-0 right-0 h-1 bg-gradient-to-r from-zenable-teal to-zenable-blue rounded"></div>
  <div class="relative flex justify-between">
    {%- for node in nodes %}
    <div class="timeline-node relative flex flex-col items-center cursor-pointer">
      <div class="w-12 h-12 bg-zenable-teal rounded-full flex items-center justify-center z-10 border-4 border-zenable-bg">
        <span class="text-white font-bold text-sm">{{ loop.index }}</span>
      </div>
      <div class="mt-4 text-center">
        <div class="text-sm font-semibold text-white">{{ node.title }}</div>
        <div class="text-xs text-slate-400">{{ node.subtitle }}</div>
      </div>
      {%- if node.tooltip %}
      <div class="timeline-tooltip absolute top-full mt-8 left-1/2 w-64 bg-zenable-bg-light border border-slate-600 rounded-xl p-4 z-20 shadow-xl">
        <div class="text-zenable-teal font-semibold mb-2">{{ node.tooltip_title|default(node.title) }}</div>
        <ul class="text-xs text-slate-300 space-y-1">
          {%- for item in node.tooltip %}
          <li>{{ item }}</li>
          {%- endfor %}
        </ul>
      </div>
      {%- endif %}
    </div>
    {%- endfor %}
  </div>
</div>
{%- endmacro -%}

{# ---------- roadmap ---------- #}
{%- macro roadmap(wip, future) -%}
<div class="grid grid-cols-2 gap-8 mt-6">
  <div>
    <h4 class="text-sm font-semibold uppercase tracking-wide text-amber-400 mb-4">Work in Progress</h4>
    <div class="space-y-3">
      {%- for item in wip %}
      <div class="bg-amber-400/10 border border-amber-400/20 rounded-xl p-4">
        <h5 class="text-white font-medium mb-1">{{ item.title }}</h5>
        <p class="text-xs text-slate-400">{{ item.desc }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
  <div>
    <h4 class="text-sm font-semibold uppercase tracking-wide text-slate-400 mb-4">Future</h4>
    <div class="space-y-3">
      {%- for item in future %}
      <div class="bg-slate-700/30 border border-slate-600/30 rounded-xl p-4">
        <h5 class="text-white font-medium mb-1">{{ item.title }}</h5>
        <p class="text-xs text-slate-400">{{ item.desc }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</div>
{%- endmacro -%}

{# ---------- flow_steps ---------- #}
{%- macro flow_steps(steps) -%}
<div class="flex items-center justify-center gap-3 mt-8 flex-wrap">
  {%- for step in steps %}
  {%- if not loop.first %}
  <span class="text-slate-500 text-xl">&rarr;</span>
  {%- endif %}
  <div class="bg-zenable-bg-light/50 border border-slate-700 rounded-lg px-6 py-3 text-center">
    <div class="text-sm font-mono text-white">{{ step }}</div>
  </div>
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- stat_grid ---------- #}
{%- macro stat_grid(stats, cols=4) -%}
<div class="grid grid-cols-{{ cols }} gap-4 mt-6">
  {%- for stat in stats %}
  <div class="bg-slate-700/50 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-zenable-teal">{{ stat.value }}</div>
    <div class="text-xs text-slate-400">{{ stat.label }}</div>
  </div>
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- icon_list ---------- #}
{%- macro icon_list(items) -%}
<ul class="space-y-3 mt-4">
  {%- for item in items %}
  <li class="flex items-center gap-3 text-sm text-slate-300">
    <span class="w-1.5 h-1.5 bg-zenable-teal rounded-full flex-shrink-0"></span>
    {{ item }}
  </li>
  {%- endfor %}
</ul>
{%- endmacro -%}

{# ---------- circles_reveal ---------- #}
{# Three overlapping circles for a Venn-style layout #}
{%- macro circles_reveal(items) -%}
<div class="flex items-center justify-center gap-8 mt-12">
  {%- for item in items %}
  <div class="w-48 h-48 border-2 border-zenable-teal/60 rounded-full flex items-center justify-center bg-zenable-teal/10">
    <span class="text-xl font-bold text-white">{{ item }}</span>
  </div>
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- level_card ---------- #}
{# Agentic landscape level card with 3-column grid #}
{%- macro level_card(level, title, tools, how, role) -%}
<section class="slide flex items-center justify-center p-12">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Level " ~ level) }}
    <h3 class="text-4xl font-bold text-white mb-8">{{ title }}</h3>
    <div class="grid grid-cols-3 gap-6">
      {{ card("Tools", tools, "teal") }}
      {{ card("How It Works", how, "blue") }}
      {{ card("Your Role", role, "amber") }}
    </div>
  </div>
</section>
{%- endmacro -%}

{# ---------- guideline_grid ---------- #}
{%- macro guideline_grid(items, cols=3) -%}
<div class="grid grid-cols-{{ cols }} gap-4 mt-6">
  {%- for item in items %}
  <div class="bg-zenable-bg-light/50 border border-slate-700 rounded-xl p-5 hover:border-zenable-teal/40 transition-all">
    <h5 class="text-white font-semibold mb-1">{{ item.title }}</h5>
    <p class="text-xs text-slate-400">{{ item.desc }}</p>
  </div>
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- resource_grid ---------- #}
{%- macro resource_grid(resources) -%}
<div class="grid grid-cols-2 gap-6 mt-8">
  {%- for r in resources %}
  <div class="bg-zenable-bg-light/50 border border-slate-700 rounded-xl p-6 hover:border-zenable-teal/40 transition-all">
    <h4 class="text-lg font-semibold text-white mb-2">{{ r.title }}</h4>
    <p class="text-sm text-slate-400">{{ r.desc }}</p>
  </div>
  {%- endfor %}
</div>
{%- endmacro -%}

{# ---------- fs_explorer ---------- #}
{# Interactive filesystem tree with clickable detail panel.
   folders: [{id, name, color, meta}]   — color is a Tailwind token e.g. "zenable-teal", "green-400"
   details: [{id, title, color, items:[{name,desc}], stats:[{value,label,color}], footer}]
   The first detail panel is shown by default. #}
{%- macro fs_explorer(folders, details) -%}
<div class="grid grid-cols-2 gap-6 fs-explorer">
  <!-- File tree -->
  <div class="bg-zenable-bg-light/50 border border-slate-700 rounded-xl p-4 font-mono text-sm">
    {%- for f in folders %}
    <div class="fs-item rounded px-2 py-1.5 cursor-pointer{{ ' fs-item-active' if loop.first else '' }}" data-fs-detail="{{ f.id }}">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-{{ f.color }}" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>
        <span class="text-{{ f.color }}">{{ f.name }}</span>
        {%- if f.meta %}<span class="text-slate-500 text-xs ml-auto">{{ f.meta }}</span>{%- endif %}
      </div>
    </div>
    {%- endfor %}
  </div>
  <!-- Detail panel -->
  <div class="bg-zenable-bg-light/30 border border-slate-700 rounded-xl p-6 min-h-[320px]">
    {%- for d in details %}
    <div class="fs-detail-content{{ '' if loop.first else ' hidden' }}" data-fs-detail-id="{{ d.id }}">
      <h4 class="text-lg font-semibold text-{{ d.color }} mb-4">{{ d.title }}</h4>
      {%- if d.items %}
      <div class="grid grid-cols-2 gap-3 text-sm">
        {%- for item in d.items %}
        <div class="bg-slate-700/50 rounded p-3">
          <div class="text-white font-medium">{{ item.name }}</div>
          {%- if item.desc %}<div class="text-xs text-slate-400">{{ item.desc }}</div>{%- endif %}
        </div>
        {%- endfor %}
      </div>
      {%- endif %}
      {%- if d.stats %}
      <div class="grid grid-cols-2 gap-4 text-sm">
        {%- for s in d.stats %}
        <div class="bg-slate-700/50 rounded p-3">
          <div class="text-2xl font-bold text-{{ s.color|default('zenable-teal') }}">{{ s.value }}</div>
          <div class="text-xs text-slate-400">{{ s.label }}</div>
        </div>
        {%- endfor %}
      </div>
      {%- endif %}
      {%- if d.footer %}
      <div class="mt-4 text-xs text-slate-500">{{ d.footer }}</div>
      {%- endif %}
    </div>
    {%- endfor %}
  </div>
</div>
{%- endmacro -%}

{# ---------- org_chart ---------- #}
{# Hierarchical org-chart / tree structure.
   root:     {title, desc}
   branches: [{title, color, children:[{title, desc}]}]
             — color is a Tailwind token e.g. "green-400", "amber-400"
   footer:   optional footer text #}
{%- macro org_chart(root, branches, footer="") -%}
<div class="flex flex-col items-center">
  <!-- Root node -->
  <div class="bg-slate-700/80 border-2 border-slate-500 rounded-xl px-6 py-3 mb-4">
    <div class="text-white font-bold text-sm uppercase tracking-wide">{{ root.title }}</div>
    {%- if root.desc %}<div class="text-xs text-slate-400">{{ root.desc }}</div>{%- endif %}
  </div>
  <!-- Connector -->
  <div class="w-px h-6 bg-slate-600"></div>
  <div class="w-[85%] h-px bg-slate-600"></div>
  <!-- Branches -->
  <div class="grid grid-cols-{{ branches|length }} gap-4 w-full mt-0">
    {%- for branch in branches %}
    <div class="flex flex-col items-center">
      <div class="w-px h-6 bg-slate-600"></div>
      <div class="bg-{{ branch.color }}/20 border-2 border-{{ branch.color }}/50 rounded-xl px-4 py-2 w-full text-center mb-3">
        <div class="text-{{ branch.color }} font-bold text-xs uppercase tracking-wide">{{ branch.title }}</div>
      </div>
      {%- if branch.children %}
      <div class="w-px h-4 bg-{{ branch.color }}/30"></div>
      <div class="space-y-2 w-full">
        {%- for child in branch.children %}
        <div class="bg-{{ branch.color }}/10 border border-{{ branch.color }}/30 rounded-lg p-2">
          <div class="text-{{ branch.color }} font-semibold text-xs">{{ child.title }}</div>
          {%- if child.desc %}<div class="text-[10px] text-slate-400">{{ child.desc }}</div>{%- endif %}
        </div>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>
    {%- endfor %}
  </div>
  {%- if footer %}
  <div class="text-sm text-slate-400 text-center mt-8">{{ footer }}</div>
  {%- endif %}
</div>
{%- endmacro -%}
