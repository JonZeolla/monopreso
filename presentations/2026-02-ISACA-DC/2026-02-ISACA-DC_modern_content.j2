{%- from "modern_macros.j2" import section_label, pill, card, card_grid, flow_steps, icon_list, circles_reveal, level_card, guideline_grid, resource_grid, timeline, section_header, split_personas, fs_explorer, org_chart, roadmap, stat_grid -%}

{# ============================================================
   ISACA-DC: Guardrails for AI Coding — Modern engine content
   ============================================================ #}

<!-- Slide 0: Title -->
<section class="slide flex items-center justify-center p-12" data-label="Intro">
  <div class="text-center fade-in">
    <h1 class="text-7xl font-bold mb-4 tracking-tight text-white">Guardrails for AI Coding</h1>
    <p class="text-2xl font-medium mb-8 italic gradient-text">Practical controls for confident adoption</p>
    <div class="flex gap-4 justify-center text-sm text-slate-300 flex-wrap">
      <span class="bg-zenable-bg-light/30 px-4 py-2 rounded-full border border-zenable-teal/30">ISACA Greater Washington, D.C.</span>
      <span class="bg-zenable-bg-light/30 px-4 py-2 rounded-full border border-zenable-teal/30">February 19, 2026</span>
    </div>
    <div class="mt-16 text-slate-500 animate-bounce">
      <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>

<!-- Slide 1: Speaker -->
<section class="slide flex items-center justify-center p-12" data-label="Speaker">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("About") }}
    <h3 class="text-4xl font-bold text-white mb-10">Jon Zeolla</h3>
    <div class="grid grid-cols-2 gap-6">
      {{ card("Zenable", "Co-founder &mdash; Enterprise Coding Agent Guardrails", "teal") }}
      {{ card("SANS Instructor", "Cloud security and DevSecOps classes", "blue") }}
      {{ card("CNCF Ambassador", "Open source contributor", "teal") }}
      {{ card("BSides Pittsburgh", "Conference organizer", "blue") }}
    </div>
  </div>
</section>

<!-- Slide 2: Motivation -->
<section class="slide flex items-center justify-center p-12" data-label="Motivation">
  <div class="max-w-4xl mx-auto w-full text-center fade-in">
    {{ section_label("Motivation") }}
    <h3 class="text-4xl font-bold text-white mb-6">I'm on a mission to make AI</h3>
    {{ circles_reveal(["Correct", "Observable", "Conformant"]) }}
  </div>
</section>

<!-- Slide 3: The Problem -->
<section class="slide flex items-center justify-center p-12" data-label="The Problem">
  <div class="max-w-4xl mx-auto w-full fade-in">
    {{ section_label("The Challenge") }}
    <h3 class="text-4xl font-bold text-white mb-8">AI Is Changing How We Code</h3>
    <div class="bg-zenable-bg-light/50 border border-slate-700 rounded-xl p-8">
      <p class="text-lg text-slate-300 leading-relaxed">Generative AI is quickly becoming a default part of the software development lifecycle. Faster delivery can also increase <span class="text-amber-400 font-semibold">security risk</span>, <span class="text-amber-400 font-semibold">operational fragility</span>, and decisions that are <span class="text-amber-400 font-semibold">difficult to review or audit</span>.</p>
    </div>
    <div class="mt-8 text-sm text-slate-400 text-center">
      How do we adopt coding assistants with confidence while maintaining strong security, governance, and assurance?
    </div>
  </div>
</section>

<!-- Slide 4: Three Levels Overview -->
{{ section_header("Framework", "Three Maturity Levels", "Progressive controls for agentic coding") }}

<!-- Slide 5: Levels Overview Flow -->
<section class="slide flex items-center justify-center p-12" data-label="Overview">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Overview") }}
    <h3 class="text-4xl font-bold text-white mb-8">Progressive Guardrails</h3>
    {{ flow_steps(["Level 1: Steer", "Level 2: Inject", "Level 3: Enforce"]) }}
    <p class="text-sm text-slate-500 mt-8 text-center">Each level builds on the last &mdash; start where you are, grow as you mature</p>
  </div>
</section>

<!-- Slide 6: Level 1 Header -->
{{ section_header("Level 1", "Built-in Steering", "Consistent expectations from the start") }}

<!-- Slide 7: Level 1 Details -->
<section class="slide flex items-center justify-center p-12" data-label="Level 1">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Level 1 &mdash; Built-in Steering") }}
    <h3 class="text-4xl font-bold text-white mb-6">Project Context &amp; Rules</h3>
    {{ card_grid([
      {"title": "Context Files", "desc": "CLAUDE.md, .cursorrules, copilot-instructions &mdash; baseline expectations in every repo", "accent": "teal"},
      {"title": "Instruction Layers", "desc": "Architecture, security patterns, data handling, and logging standards baked into the agent's context", "accent": "teal"},
      {"title": "Reduce Variability", "desc": "Define 'how we do things here' so AI-generated code aligns with team conventions", "accent": "blue"},
      {"title": "Improve Repeatability", "desc": "Consistent outputs across developers, projects, and coding agents", "accent": "blue"},
    ]) }}
  </div>
</section>

<!-- Slide 8: Level 2 Header -->
{{ section_header("Level 2", "Context-Injection Agents", "Right guidance at the right time") }}

<!-- Slide 9: Level 2 Details -->
<section class="slide flex items-center justify-center p-12" data-label="Level 2">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Level 2 &mdash; Context-Injection Agents") }}
    <h3 class="text-4xl font-bold text-white mb-6">Dynamic, Targeted Guidance</h3>
    {{ card_grid([
      {"title": "What's Changing", "desc": "Deliver relevant requirements and constraints based on the files and components being modified", "accent": "teal"},
      {"title": "Type of Work", "desc": "Different guidance for new features, bug fixes, refactors, and security-sensitive changes", "accent": "teal"},
      {"title": "Approved Patterns", "desc": "Surface approved libraries, design patterns, and architectural decisions when they're needed", "accent": "blue"},
      {"title": "Workflow-Aware", "desc": "Guidance adapts based on where the developer is in the workflow &mdash; design, implementation, or review", "accent": "blue"},
    ]) }}
  </div>
</section>

<!-- Slide 10: Level 3 Header -->
{{ section_header("Level 3", "Policy-as-Code Guardrails", "Deterministic enforcement with evidence") }}

<!-- Slide 11: Level 3 Details -->
<section class="slide flex items-center justify-center p-12" data-label="Level 3">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Level 3 &mdash; Policy-as-Code") }}
    <h3 class="text-4xl font-bold text-white mb-6">Enforce in PRs &amp; CI/CD</h3>
    {{ card_grid([
      {"title": "Deterministic Checks", "desc": "Policy-as-code guardrails that run in pull requests and CI/CD pipelines", "accent": "teal"},
      {"title": "Security &amp; Compliance", "desc": "Enforce security, quality, and compliance requirements with measurable outcomes", "accent": "teal"},
      {"title": "Audit-Ready Evidence", "desc": "Every check produces traceable, reviewable evidence for governance and audit", "accent": "blue"},
      {"title": "Continuous Learning", "desc": "Guardrails learn from code changes and review outcomes to improve Levels 1 and 2", "accent": "blue"},
    ]) }}
  </div>
</section>

<!-- Slide 12: The Feedback Loop -->
<section class="slide flex items-center justify-center p-12" data-label="Feedback Loop">
  <div class="max-w-4xl mx-auto w-full text-center fade-in">
    {{ section_label("Key Insight") }}
    <h3 class="text-4xl font-bold text-white mb-8">The Feedback Loop</h3>
    {{ flow_steps(["Level 3 Enforces", "Learns from Outcomes", "Improves Levels 1 &amp; 2"]) }}
    <p class="text-sm text-slate-500 mt-8">Controls strengthen over time &mdash; each review cycle makes the next one better</p>
  </div>
</section>

<!-- Slide 13: Getting Started -->
<section class="slide flex items-center justify-center p-12" data-label="Getting Started">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Roadmap") }}
    <h3 class="text-4xl font-bold text-white mb-6">Getting Started</h3>
    {{ guideline_grid([
      {"title": "Start with Level 1", "desc": "Add context files to every repo &mdash; CLAUDE.md, .cursorrules, or equivalent"},
      {"title": "Define Your Standards", "desc": "Codify architecture, security patterns, and coding conventions"},
      {"title": "Automate Guidance", "desc": "Build context-injection agents that deliver the right rules at the right time"},
      {"title": "Enforce in CI/CD", "desc": "Add deterministic policy checks to PRs and pipelines"},
      {"title": "Measure Outcomes", "desc": "Track compliance, defect rates, and review quality over time"},
      {"title": "Close the Loop", "desc": "Feed enforcement results back into context files and agent guidance"},
    ]) }}
  </div>
</section>

<!-- Slide 14: Resources -->
<section class="slide flex items-center justify-center p-12" data-label="Resources">
  <div class="max-w-5xl mx-auto w-full fade-in">
    {{ section_label("Resources") }}
    <h3 class="text-4xl font-bold text-white mb-6">Want more?</h3>
    {{ resource_grid([
      {"title": "Training", "desc": "SEC545: GenAI and LLM Application Security &mdash; sans.org/sec545"},
      {"title": "Learn the Fundamentals", "desc": "3Blue1Brown and The Latent Space podcast"},
      {"title": "OWASP", "desc": "AI Testing Guide and Top 10 for LLM Applications"},
      {"title": "Community", "desc": "DEFCON's AI Village &mdash; aivillage.org"},
    ]) }}
    <p class="text-center text-slate-500 text-sm mt-8">Or, as always... just ask :)</p>
  </div>
</section>

<!-- Slide 15: Questions -->
<section class="slide flex items-center justify-center p-12" data-label="Questions">
  <div class="text-center fade-in">
    <h3 class="text-5xl font-bold text-white mb-6">Questions?</h3>
    <p class="text-slate-400">Thank you!</p>
    <p class="text-sm text-slate-500 mt-4">linkedin.com/in/jonzeolla</p>
  </div>
</section>
