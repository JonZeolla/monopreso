.sans-slide img.slide-img { max-width: 90%; max-height: 70vh; border-radius: 8px; display: block; margin: 0 auto; }
.sans-slide img.plain { border: none; box-shadow: none; }

/* ══════════════════════════════════════════════════════════════════
   DARK VISUAL SLIDE STYLES
   Rich, dark-themed slides matching the interactive app components
   ══════════════════════════════════════════════════════════════════ */
.vis-slide {
  min-height: 100vh;
  scroll-snap-align: start;
  background: var(--vis-bg) !important;
  display: flex;
  flex-direction: column;
  padding: 96px 56px 40px 56px;
  box-sizing: border-box;
  font-family: 'Fira Sans', Arial, Helvetica, sans-serif;
  color: var(--vis-text);
}
.vis-slide .vis-label {
  font-size: 12px;
  font-weight: 600;
