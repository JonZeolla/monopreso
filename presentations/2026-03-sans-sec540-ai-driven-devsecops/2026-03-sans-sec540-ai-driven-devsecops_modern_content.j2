  background: rgba(34,197,94,0.05);
  border: 1px solid rgba(34,197,94,0.2);
  color: #86efac;
}
/* Grid helpers */
.vis-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.vis-grid-5-7 { display: grid; grid-template-columns: 5fr 7fr; gap: 24px; }
.vis-flex { display: flex; }
.vis-gap-2 { gap: 8px; }
.vis-gap-3 { gap: 12px; }
.vis-gap-4 { gap: 16px; }
.vis-gap-5 { gap: 20px; }
.vis-gap-6 { gap: 24px; }
.vis-items-center { align-items: center; }
.vis-flex-1 { flex: 1; }
.vis-shrink-0 { flex-shrink: 0; }
/* Arrow SVG */
.vis-arrow {
  width: 20px; height: 20px;
  color: var(--vis-dim);
  flex-shrink: 0;
}
/* Colored borders/bgs for agent cards */
.vis-blue-card { background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2); border-radius: 12px; padding: 16px; }
.vis-purple-card { background: rgba(168,85,247,0.05); border: 1px solid rgba(168,85,247,0.2); border-radius: 12px; padding: 16px; }
.vis-teal-card { background: rgba(20,184,166,0.05); border: 1px solid rgba(20,184,166,0.2); border-radius: 12px; padding: 16px; }
.vis-amber-card { background: rgba(245,158,11,0.05); border: 1px solid rgba(245,158,11,0.2); border-radius: 12px; padding: 16px; }
.vis-red-card { background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 16px; }
.vis-green-card { background: rgba(34,197,94,0.05); border: 1px solid rgba(34,197,94,0.2); border-radius: 12px; padding: 16px; }
