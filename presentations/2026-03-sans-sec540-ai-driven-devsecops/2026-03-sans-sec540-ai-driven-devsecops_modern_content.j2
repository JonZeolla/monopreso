  color: var(--sans-charcoal);
  font-size: 18px;
}

/* ── Lists ─────────────────────────────────────────────────────── */
.sans-slide ul {
  list-style: disc;
  padding-left: 36px;
  margin: 12px 0 20px 0;
}
.sans-slide ul li {
  font-size: 24px;
