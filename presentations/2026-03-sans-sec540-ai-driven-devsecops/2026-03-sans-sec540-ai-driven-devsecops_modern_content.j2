  (function(){
    var step = 0;
    // [elemId, ctx%, mcp%, prompt%, files%, tokens, nextBtnLabel]
    var steps = [
      ['ctx-step1', 3,  0,  0, 0, 16000,  'Connect MCP Server ▶'],
      ['ctx-step2', 3,  33, 0, 0, 76000,  'Send Prompt ▶'],
      ['ctx-step3', 3,  33, 2, 0, 78400,  'Allow Read ▶'],
      ['ctx-step4', 3,  33, 3, 0, 80200,  'Allow ▶'],
      ['ctx-step5', 3,  33, 3, 4, 88000,  'Allow Read ▶'],
      ['ctx-step6', 3,  33, 3, 10,100200, ''],
    ];
    window.ctxNext = function(){
      if(step >= steps.length) return;
      var s = steps[step];
      document.getElementById(s[0]).style.display = 'block';
      var log = document.getElementById('ctx-log');
      setTimeout(function(){ log.scrollTop = log.scrollHeight; }, 50);
      document.getElementById('ctx-bar-ctx').style.height = s[1]+'%';
      document.getElementById('ctx-bar-mcp').style.height = s[2]+'%';
      document.getElementById('ctx-bar-prompt').style.height = s[3]+'%';
      document.getElementById('ctx-bar-files').style.height = s[4]+'%';
      document.getElementById('ctx-counter').textContent = s[5].toLocaleString();
      if(s[1]>0) document.getElementById('ctx-pct-ctx').textContent = 'Context files '+s[1]+'%';
      if(s[2]>0) document.getElementById('ctx-pct-mcp').textContent = 'MCP schemas '+s[2]+'%';
      if(s[3]>0) document.getElementById('ctx-pct-prompt').textContent = 'Conversation '+s[3]+'%';
      if(s[4]>0) document.getElementById('ctx-pct-files').textContent = 'File reads '+s[4]+'%';
      step++;
      if(step < steps.length){
        document.getElementById('ctx-next-btn').textContent = steps[step-1][6];
      } else {
        document.getElementById('ctx-next-btn').style.display = 'none';
      }
    };
  })();
  </script>
