/* ── Links ─────────────────────────────────────────────────────── */
.sans-slide a { color: var(--sans-link); text-decoration: none; }
.sans-slide a:hover { text-decoration: underline; }
.sans-slide a.orange-link { color: var(--sans-orange); font-weight: 700; }

/* ── Tables ────────────────────────────────────────────────────── */
.sans-slide table { border-collapse: collapse; width: 100%; font-size: 22px; margin: 16px 0; }
.sans-slide th { background: var(--sans-teal); color: var(--sans-white); font-weight: 700; text-align: left; padding: 14px 20px; }
.sans-slide td { padding: 14px 20px; border-bottom: 1px solid #E0E0E0; color: var(--sans-body); }
.sans-slide tr.highlight-row { color: var(--sans-orange); font-weight: 700; }

/* ── Code blocks ───────────────────────────────────────────────── */
.sans-slide pre { background: #1E1E1E; color: #D4D4D4; border-radius: 6px; padding: 20px; font-size: 15px; line-height: 1.5; overflow-x: auto; margin: 16px 0; font-family: 'Fira Mono', 'Consolas', monospace; }
.sans-slide code { font-family: 'Fira Mono', 'Consolas', monospace; }
.sans-slide p code, .sans-slide li code { background: #F0F0F0; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; color: var(--sans-charcoal); }

/* ── Orange/teal accents ──────────────────────────────────────── */
.sans-orange { color: var(--sans-orange) !important; }
.sans-teal   { color: var(--sans-teal) !important; }

/* ── Title slide ──────────────────────────────────────────────── */
.sans-title-slide {
  background: var(--sans-orange) url('presentations/2026-03-sans-sec540-ai-driven-devsecops/img/sans-title-ace-bg.jpg') center/cover no-repeat !important;
  color: var(--sans-white) !important;
