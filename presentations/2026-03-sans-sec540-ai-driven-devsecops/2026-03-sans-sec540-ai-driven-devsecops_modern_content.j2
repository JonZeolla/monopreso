}

/* ── Slide base ────────────────────────────────────────────────── */
.sans-slide {
  min-height: 100vh;
  scroll-snap-align: start;
  background: var(--sans-white);
  display: flex;
  flex-direction: column;
  padding: 100px 64px 48px 64px;
  box-sizing: border-box;
  font-family: 'Fira Sans', Arial, Helvetica, sans-serif;
  color: var(--sans-body);
}

/* ── Headings ──────────────────────────────────────────────────── */
