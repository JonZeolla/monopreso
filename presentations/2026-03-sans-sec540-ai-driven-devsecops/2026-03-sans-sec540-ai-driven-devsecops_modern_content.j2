  text-align: center;
  justify-content: center;
  align-items: center;
}
.sans-end-slide p, .sans-end-slide a { color: var(--sans-offwhite); }
.sans-end-slide a { color: var(--sans-link); }

/* ── Section Divider ──────────────────────────────────────────── */
.sans-section-divider {
  background: var(--sans-orange) url('presentations/2026-03-sans-sec540-ai-driven-devsecops/img/sans-title-ace-bg.jpg') center/cover no-repeat !important;
